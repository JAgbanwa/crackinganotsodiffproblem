# .env.example  —  Copy to .env and edit before deploying
#
# docker compose uses these values to configure the BOINC server.

# Your VPS public URL (no trailing slash). Use http until you add SSL.
URL_BASE=http://YOUR-VPS-IP-OR-DOMAIN

# Database credentials (change these!)
MYSQL_ROOT_PASSWORD=root_changeme_PLEASE
DB_USER=boincadm
DB_PASS=boinc_changeme_PLEASE
DB_NAME=s3ceq
